{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "RIOT: build",
            "type": "shell",
            "command": "make",
            "args": ["all"],
            "options": {
                "cwd": "${workspaceFolder}/src"
            },
            "group": "build",
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "RIOT: clean build",
            "type": "shell",
            "command": "make",
            "args": ["clean", "all"],
            "options": {
                "cwd": "${workspaceFolder}/src"
            },
            "group": "build",
            "problemMatcher": ["$gcc"]
        }
    ]
}
